{
  "name": "business-advisor-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:apply": "vite --host 0.0.0.0 --mode apply",
    "build": "vite build",
    "build:aws": "vite build && node ../tools/aws/prerender-spa-routes.js dist && node ../tools/aws/compress-dist.js dist",
    "build:apply": "vite build --mode apply",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:a11y": "jest --config jest.config.cjs test/accessibility --runInBand --forceExit",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:auth": "cypress run --spec \"cypress/e2e/auth/**\"",
    "cy:run:advisor": "cypress run --spec \"cypress/e2e/advisor/**\"",
    "cy:run:crm": "cypress run --spec \"cypress/e2e/crm/**\"",
    "cy:run:ems": "cypress run --spec \"cypress/e2e/ems/**\"",
    "cy:run:payroll": "cypress run --spec \"cypress/e2e/payroll/**\"",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.2.0",
    "axe-core": "^4.12.0",
    "babel-jest": "^30.4.1",
    "babel-plugin-transform-vite-meta-env": "^1.0.3",
    "cypress": "^15.15.0",
    "cypress-axe": "^1.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "msw": "^2.14.6",
    "typescript": "~6.0.2",
    "undici": "^7.27.0",
    "vite": "^7.3.3"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.2.4",
    "axios": "^1.16.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.75.0",
    "react-hot-toast": "^2.6.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.2.4",
    "yup": "^1.7.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "qs": "^6.15.2",
    "esbuild": "^0.28.1"
  }
}
